          <Layer level="OVERLAY">
            <FontString name="$parentLabel" inherits="GameFontNormalSmall" text="Actions">
              <Anchors><Anchor point="CENTER"/></Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
            this:SetBackdropColor(0.1, 0.1, 0.1, 1)
            this:SetBackdropBorderColor(0.6, 0.6, 0.6, 1)
          </OnLoad>
          <OnClick>
            EreaRpMasterItemEditorFrame:ShowTab(3)
          </OnClick>
        </Scripts>
