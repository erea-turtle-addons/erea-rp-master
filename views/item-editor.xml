<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

  <!-- Item Editor Dialog -->
  <Frame name="EreaRpMasterItemEditorFrame" parent="UIParent" frameStrata="DIALOG" toplevel="true" enableMouse="true" movable="true" hidden="true">
    <Size>
      <AbsDimension x="860" y="700"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
              edgeFile="Interface\DialogFrame\UI-DialogBox-Border"
              tile="true">
      <EdgeSize>
        <AbsValue val="32"/>
      </EdgeSize>
      <TileSize>
        <AbsValue val="32"/>
      </TileSize>
      <BackgroundInsets>
        <AbsInset left="11" right="12" top="12" bottom="11"/>
      </BackgroundInsets>
    </Backdrop>

    <Layers>
      <Layer level="OVERLAY">
        <!-- Title -->
        <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Edit RP Item">
          <Anchors>
            <Anchor point="TOP">
              <Offset>
                <AbsDimension x="0" y="-20"/>
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>

    <Frames>
      <!-- Draggable title bar -->
      <Frame name="$parentTitleBar" enableMouse="true">
        <Size>
          <AbsDimension x="0" y="30"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="10" y="-10"/>
            </Offset>
          </Anchor>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-30" y="-10"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>

      <!-- Close button -->
      <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-5" y="-5"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Button>

      <!-- Tab buttons (custom backdrop style matching main-window tabs) -->
      <Button name="$parentTab1" enableMouse="true">
        <Size>
          <AbsDimension x="100" y="28"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="15" y="-45"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
                  edgeFile="Interface\Tooltips\UI-Tooltip-Border"
                  tile="true">
          <EdgeSize><AbsValue val="12"/></EdgeSize>
          <TileSize><AbsValue val="16"/></TileSize>
          <BackgroundInsets><AbsInset left="3" right="3" top="3" bottom="3"/></BackgroundInsets>
        </Backdrop>
        <Layers>
          <Layer level="OVERLAY">
            <FontString name="$parentLabel" inherits="GameFontNormalSmall" text="Definition">
              <Anchors><Anchor point="CENTER"/></Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
            this:SetBackdropColor(0.1, 0.1, 0.1, 1)
            this:SetBackdropBorderColor(0.6, 0.6, 0.6, 1)
          </OnLoad>
          <OnClick>
            EreaRpMasterItemEditorFrame:ShowTab(1)
          </OnClick>
        </Scripts>
      </Button>

      <Button name="$parentTab2" enableMouse="true">
        <Size>
          <AbsDimension x="100" y="28"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="$parentTab1" relativePoint="RIGHT">
            <Offset><AbsDimension x="4" y="0"/></Offset>
          </Anchor>
        </Anchors>
        <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
                  edgeFile="Interface\Tooltips\UI-Tooltip-Border"
                  tile="true">
          <EdgeSize><AbsValue val="12"/></EdgeSize>
          <TileSize><AbsValue val="16"/></TileSize>
          <BackgroundInsets><AbsInset left="3" right="3" top="3" bottom="3"/></BackgroundInsets>
        </Backdrop>
        <Layers>
          <Layer level="OVERLAY">
            <FontString name="$parentLabel" inherits="GameFontNormalSmall" text="Creation">
              <Anchors><Anchor point="CENTER"/></Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
            this:SetBackdropColor(0.1, 0.1, 0.1, 1)
            this:SetBackdropBorderColor(0.6, 0.6, 0.6, 1)
          </OnLoad>
          <OnClick>
            EreaRpMasterItemEditorFrame:ShowTab(2)
          </OnClick>
        </Scripts>
      </Button>

      <Button name="$parentTab3" enableMouse="true">
        <Size>
          <AbsDimension x="100" y="28"/>
        </Size>
        <Anchors>
