            </Size>
            <Anchors>
              <Anchor point="TOPLEFT">
                <Offset>
                  <AbsDimension x="390" y="-327"/>
                </Offset>
              </Anchor>
            </Anchors>
          </Button>

          <!-- Copy left arrow button (template -> default) -->
