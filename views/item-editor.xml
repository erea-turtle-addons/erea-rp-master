                    </Anchors>
                    <FontString inherits="ChatFontNormal"/>
                    <Scripts>
                      <OnLoad>
                        this:SetTextInsets(5, 5, 5, 5)
                        this:SetMaxLetters(0)
                      </OnLoad>
                      <OnTextChanged>
                        EreaRpMasterItemEditorDefaultContentScroll:UpdateScrollChildRect()
                      </OnTextChanged>
                      <OnCursorChanged>
                        ScrollingEdit_OnCursorChanged(arg1, arg2, arg3, arg4)
                      </OnCursorChanged>
                      <OnEscapePressed>
                        this:ClearFocus()
                      </OnEscapePressed>
                    </Scripts>
                  </EditBox>
                </Frames>
                <Scripts>
                  <OnLoad>
                    this:SetScrollChild(EreaRpMasterItemEditorDefaultContentEditBox)
                  </OnLoad>
                </Scripts>
              </ScrollFrame>
            </Frames>
          </Frame>

          <!-- Copy right arrow button (default -> template) -->
