                <Size>
                  <AbsDimension x="760" y="50"/>
                </Size>
                <Anchors>
                  <Anchor point="TOPLEFT">
                    <Offset>
                      <AbsDimension x="5" y="-5"/>
                    </Offset>
                  </Anchor>
                </Anchors>
                <FontString inherits="ChatFontNormal"/>
                <Scripts>
                  <OnLoad>
                    this:SetTextInsets(5, 5, 5, 5)
                    this:SetMaxLetters(120)
                  </OnLoad>
                  <OnEscapePressed>
                    this:ClearFocus()
                  </OnEscapePressed>
                </Scripts>
              </EditBox>
            </Frames>
          </Frame>

          <!-- Default content (left column): backdrop + ScrollFrame + EditBox -->
          <Frame name="EreaRpMasterItemEditorFrameDefaultContentContainer">
            <Size>
              <AbsDimension x="375" y="330"/>
