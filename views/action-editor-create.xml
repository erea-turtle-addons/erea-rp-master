<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

  <!-- ======================================================================
       action-editor-create.xml - Create Object Editor Template
       ======================================================================
       PURPOSE: Virtual template for the Create Object method editor
       PARAMETERS:
         - objectGuid: object_dropdown (required)
         - customText: text_with_placeholder (optional)
         - additionalText: text_with_placeholder (optional)
         - customNumber: number (optional)
       USAGE: CreateFrame("Frame", name, parent, "EreaRpMasterCreateEditorTemplate")
       ====================================================================== -->

  <Frame name="EreaRpMasterCreateEditorTemplate" virtual="true">
    <Size>
      <AbsDimension x="360" y="310"/>
    </Size>
    <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
              edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
      <EdgeSize><AbsValue val="10"/></EdgeSize>
      <TileSize><AbsValue val="16"/></TileSize>
      <BackgroundInsets><AbsInset left="3" right="3" top="3" bottom="3"/></BackgroundInsets>
    </Backdrop>
    <Scripts>
      <OnLoad>
        this:SetBackdropColor(0.1, 0.1, 0.1, 0.8)
        this:SetBackdropBorderColor(0.35, 0.35, 0.45, 1)
      </OnLoad>
    </Scripts>
    <Layers>
      <Layer level="OVERLAY">
        <!-- Title: y=-5 -->
        <FontString name="$parentTitle" inherits="GameFontNormal">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="7" y="-7"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <!-- Object dropdown label: y=-30 (title bottom ~-19, 11px gap) -->
        <!-- Object dropdown created in Lua at y=-52 (visual texture extends 24px above anchor; -52+24=-28 clears label bottom at -44) -->
        <FontString name="$parentObjectLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-30"/></Offset>
            </Anchor>
          </Anchors>
          <Text>Object to create:</Text>
        </FontString>
        <!-- Custom text: label y=-88, edit y=-106 (8px gap), hint y=-140 -->
        <FontString name="$parentCustomTextLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-88"/></Offset>
            </Anchor>
          </Anchors>
          <Text>Custom text for new object:</Text>
        </FontString>
        <FontString name="$parentCustomTextHint" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-140"/></Offset>
            </Anchor>
          </Anchors>
          <Text>|cFF888888(Use {custom-text} to copy source item's text)|r</Text>
        </FontString>
        <!-- Additional text: label y=-164, edit y=-182 (8px gap), hint y=-216 -->
        <FontString name="$parentAdditionalTextLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-164"/></Offset>
            </Anchor>
          </Anchors>
          <Text>Additional text for new object:</Text>
        </FontString>
        <FontString name="$parentAdditionalTextHint" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-216"/></Offset>
            </Anchor>
          </Anchors>
          <Text>|cFF888888(Use {additional-text} to copy source item's additional text)|r</Text>
        </FontString>
        <!-- Counter: label y=-240, edit y=-258 (8px gap), hint y=-292 -->
        <FontString name="$parentCustomNumberLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-240"/></Offset>
            </Anchor>
          </Anchors>
          <Text>Counter for new object:</Text>
        </FontString>
        <FontString name="$parentCustomNumberHint" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="10" y="-292"/></Offset>
            </Anchor>
          </Anchors>
          <Text>|cFF888888(Use {item-counter} to copy source item's counter)|r</Text>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <!-- Object dropdown created in Lua (UIDropDownMenuTemplate needs unique global name) -->
      <EditBox name="$parentCustomTextEdit" inherits="InputBoxTemplate" autoFocus="false">
        <Size>
          <AbsDimension x="340" y="25"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset><AbsDimension x="10" y="-106"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnEscapePressed>
            this:ClearFocus()
          </OnEscapePressed>
        </Scripts>
      </EditBox>
      <EditBox name="$parentAdditionalTextEdit" inherits="InputBoxTemplate" autoFocus="false">
        <Size>
          <AbsDimension x="340" y="25"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset><AbsDimension x="10" y="-182"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnEscapePressed>
            this:ClearFocus()
          </OnEscapePressed>
        </Scripts>
      </EditBox>
      <EditBox name="$parentCustomNumberEdit" inherits="InputBoxTemplate" autoFocus="false">
        <Size>
          <AbsDimension x="100" y="25"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset><AbsDimension x="10" y="-258"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnEscapePressed>
            this:ClearFocus()
          </OnEscapePressed>
        </Scripts>
      </EditBox>
    </Frames>
  </Frame>

</Ui>
