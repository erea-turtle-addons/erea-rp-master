<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

  <!-- ======================================================================
       action-editor-merge.xml - Merge Cinematic Editor Template
       ======================================================================
       PURPOSE: Virtual template for the Merge Cinematic method editor
       PARAMETERS: mergeGroup (merge_group_dropdown)
       USAGE: CreateFrame("Frame", name, parent, "EreaRpMasterMergeEditorTemplate")
       NOTE: Cinematic UI (speaker, dialogue, sides) is created dynamically
             by EreaRpMasterCinematicComponent. Dropdowns are created in Lua.
       ====================================================================== -->

  <Frame name="EreaRpMasterMergeEditorTemplate" virtual="true">
    <Size>
      <AbsDimension x="360" y="550"/>
    </Size>
    <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
              edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
      <EdgeSize><AbsValue val="10"/></EdgeSize>
      <TileSize><AbsValue val="16"/></TileSize>
      <BackgroundInsets><AbsInset left="3" right="3" top="3" bottom="3"/></BackgroundInsets>
    </Backdrop>
    <Scripts>
      <OnLoad>
        this:SetBackdropColor(0.1, 0.1, 0.1, 0.8)
        this:SetBackdropBorderColor(0.35, 0.35, 0.45, 1)
      </OnLoad>
    </Scripts>
    <Layers>
      <Layer level="OVERLAY">
        <FontString name="$parentTitle" inherits="GameFontNormal">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="7" y="-7"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <!-- Row 2: Group ID + Invocation threshold on one line at y=-44 -->
        <!-- NOTE: Text set via Lua SetText — WoW 1.12 does not render <Text> on virtual template FontStrings -->
        <FontString name="$parentIdLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="7" y="-64"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <FontString name="$parentAmountLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOPLEFT">
              <Offset><AbsDimension x="380" y="-64"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <!-- Group selection dropdown created in Lua (UIDropDownMenuTemplate requires CreateFrame) -->
      <EditBox name="$parentIdEdit" inherits="InputBoxTemplate" autoFocus="false">
        <Size>
          <AbsDimension x="275" y="25"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset><AbsDimension x="73" y="-55"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnEscapePressed>
            this:ClearFocus()
          </OnEscapePressed>
        </Scripts>
      </EditBox>
      <EditBox name="$parentAmountEdit" inherits="InputBoxTemplate" autoFocus="false">
        <Size>
          <AbsDimension x="50" y="25"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset><AbsDimension x="495" y="-55"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnEscapePressed>
            this:ClearFocus()
          </OnEscapePressed>
        </Scripts>
      </EditBox>
      <!-- Cinematic component is created dynamically in Lua below the header -->
    </Frames>
  </Frame>

</Ui>
